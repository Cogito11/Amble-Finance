{
  "name": "amble-finance",
  "productName": "Amble",
  "private": true,
  "version": "1.2.0",
  "homepage": "https://github.com/Cogito11/Amble-Finance",
  "author": {
    "name": "Cole Bishop",
    "email": "cdbishop2005@gmail.com"
  },
  "description": "A personal finance tracker and budget tool",
  "main": "main.js",
  "scripts": {
    "start": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "vite build && electron-builder",
    "build:dir": "vite build && electron-builder --dir"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "lucide-react": "^0.383.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.10",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "cross-env": "^7.0.3"
  },
  "build": {
    "appId": "com.bishop.amble",
    "artifactName": "Amble_${version}_Setup_${os}_${arch}.${ext}",
    "files": [
      "dist/**/*",
      "main.js",
      "Amble/assets/**/*"
    ],
    "win": {
      "target": ["portable", "nsis"],
      "icon": "Amble/assets/logos/AmbleLogo.ico"
    },
    "linux": {
      "target": ["appImage", "deb"],
      "icon": "Amble/assets/logos/icons",
      "category": "Finance",
      "maintainer": "Cole Bishop <cdbishop2005@gmail.com>"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "Amble/assets/logos/AmbleLogo.png"
    },
    "portable": {
      "artifactName": "Amble_${version}_Portable_${os}_${arch}.${ext}"
    },
    "appImage": {
      "artifactName": "Amble_${version}_${os}_${arch}.${ext}"
    }
  }
}
